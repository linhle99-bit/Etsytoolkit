# Supabase backend cho Auth + Cloud sync mockup sets.
# Copy file này thành .env.local rồi điền key thật.
# Trên Cloudflare Pages: set 2 biến này trong Project → Settings → Environment variables.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Optional defaults (app vẫn đọc keys từ localStorage qua Settings UI)
VITE_DEFAULT_TRELLO_KEY=
VITE_DEFAULT_TRELLO_TOKEN=
VITE_DEFAULT_CLAUDE_KEY=
